local function C_3()
local script = G2L["3"];
	local RunService = game:GetService("RunService")
	local Players = game:GetService("Players")
	local TweenService = game:GetService("TweenService")
	local SoundService = game:GetService("SoundService")
	
	local function getScreenGui()
		local p = script.Parent
		while p do
			if p:IsA("ScreenGui") then return p end
			p = p.Parent
		end
	end
	local screenGui = getScreenGui()
	if not screenGui then return end
	
	-- Play sound on startup
	local introSound = Instance.new("Sound")
	introSound.SoundId = "rbxassetid://101797982999673"
	introSound.Volume = 1
	introSound.Parent = SoundService
	introSound:Play()
	
	-- Only move to CoreGui if NOT in Studio
	if not RunService:IsStudio() then
		local CoreGui = game:GetService("CoreGui")
		screenGui.Parent = CoreGui
	end
	
	-- Intro animation
	local canvasGroup = screenGui:FindFirstChild("CanvasGroup")
	if canvasGroup then
		-- Start CanvasGroup invisible
		canvasGroup.GroupTransparency = 1
		-- Fade in CanvasGroup immediately
		local fadeIn = TweenService:Create(
			canvasGroup,
			TweenInfo.new(6, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
			{GroupTransparency = 0}
		)
		fadeIn:Play()
		local keyFrame = canvasGroup:FindFirstChild("KeyFrame")
		if keyFrame then
			local innerframe = keyFrame:FindFirstChild("innerframe")
			if innerframe then
				local accent = innerframe:FindFirstChild("ACCENT")
				if accent then
					-- Start at 0 width
					accent.Size = UDim2.new(0, 0, 0, 4)
					-- Wait 1.5 seconds then slide to full width
					task.wait(2)
					local slideIn = TweenService:Create(
						accent,
						TweenInfo.new(3, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out),
						{Size = UDim2.new(1, 0, 0, 4)}
					)
					slideIn:Play()
				end
			end
		end
	end
end;
