local function C_2()
local script = G2L["2"];
	local HttpService = game:GetService("HttpService")
	local CONFIG_FILE = "keydata.json"
	
	local function saveKeyData(key)
		local data = {
			timestamp = os.time(),
			key = key
		}
		writefile(CONFIG_FILE, HttpService:JSONEncode(data))
	end
	
	local function getScreenGui()
		local p = script.Parent
		while p do
			if p:IsA("ScreenGui") then return p end
			p = p.Parent
		end
	end
	
	local screenGui = getScreenGui()
	if not screenGui then return end
	
	local canvasGroup = screenGui:FindFirstChild("CanvasGroup")
	if not canvasGroup then return end
	
	local keyFrame = canvasGroup:FindFirstChild("KeyFrame")
	if not keyFrame then return end
	
	local innerframe = keyFrame:FindFirstChild("innerframe")
	if not innerframe then return end
	
	local enterkey = innerframe:FindFirstChild("enterkey")
	local textboxFrame = innerframe:FindFirstChild("textbox")
	if not enterkey or not textboxFrame then return end
	
	local button = enterkey:FindFirstChild("button")
	local buttonText = button and button:FindFirstChild("text")
	local textboxFrameInner = textboxFrame:FindFirstChild("textboxFrame")
	local textbox = textboxFrameInner and textboxFrameInner:FindFirstChild("textbox")
	if not button or not buttonText or not textbox then return end
	
	button.MouseButton1Click:Connect(function()
		local enteredKey = textbox.Text
	
		buttonText.Text = "Checking..."
		task.wait(0.5)
	
		if enteredKey == CORRECT_KEY then
			-- Correct key, SAVE TO JSON
			saveKeyData(CORRECT_KEY)
			buttonText.Text = "Valid! Loading..."
	
			-- Load main GUI
			pcall(function()
				loadstring(game:HttpGet("https://raw.githubusercontent.com/agarv69/Open-Source-Scripts/refs/heads/main/AGARWAREV3.lua"))()
			end)
	
			-- Destroy key GUI
			canvasGroup:Destroy()
		else
			-- Wrong key
			buttonText.Text = "Key invalid!"
			task.wait(2)
			buttonText.Text = "Enter Key"
		end
	end)
end;
task.spawn(C_2);
